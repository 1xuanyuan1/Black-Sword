[node name="BattleArena" type="Node2D"]
editor_description = "完整战斗场景：组装地图、玩家、玩法系统及所有运行时对象层。"
y_sort_enabled = true
script = ExtResource("1_arena")

[node name="Environment" type="Node2D" parent="."]
editor_description = "地图、地形碰撞和氛围效果的容器。"
y_sort_enabled = true

[node name="AbandonedTempleMap" parent="Environment" instance=ExtResource("2_map")]

[node name="ActorLayer" type="Node2D" parent="."]
editor_description = "玩家、普通敌人和 Boss 的运行时容器。"
y_sort_enabled = true

[node name="PlayerSpawnPoint" type="Marker2D" parent="ActorLayer"]
editor_description = "所选玩家角色预设的出生位置。"

[node name="PickupLayer" type="Node2D" parent="."]
editor_description = "经验球与其他可拾取物的运行时容器。"

[node name="ProjectileLayer" type="Node2D" parent="."]
editor_description = "玩家和敌方弹丸的运行时容器。"

[node name="EffectLayer" type="Node2D" parent="."]
editor_description = "伤害数字、攻击范围和技能特效的运行时容器。"

[node name="GameplaySystems" type="Node" parent="."]
editor_description = "不直接显示的战斗规则和系统容器。"

[node name="RuntimeObjectPool" type="Node" parent="GameplaySystems"]
editor_description = "Reuse projectiles, experience orbs, and short-lived effects during dense waves."
script = ExtResource("10_pool")

[node name="SkillController" type="Node" parent="GameplaySystems"]
editor_description = "管理主动技能冷却与招式执行；槽位、等级和候选由 SkillInventory 持有。"
script = ExtResource("4_skills")

[node name="ItemDropSystem" type="Node" parent="GameplaySystems"]
editor_description = "负责陶罐、精英掉落、四波保底、拾取上限与道具效果。"
script = ExtResource("5_items")

[node name="EvolutionSystem" type="Node" parent="GameplaySystems"]
editor_description = "管理永久悟道宝匣、合法进阶候选与单次消费。"
script = ExtResource("6_evolution")

[node name="RunController" type="Node" parent="GameplaySystems"]
editor_description = "单局统计与一次性 RunResult 所有者。"
script = ExtResource("7_run")

[node name="WaveDirector" type="Node" parent="GameplaySystems"]
editor_description = "十二波状态、计时、休整和 Boss 死亡门控。"
script = ExtResource("8_wave")

[node name="SpawnDirector" type="Node" parent="GameplaySystems"]
editor_description = "波次敌群、精英词缀、小 Boss 与最终 Boss 生成。"
script = ExtResource("9_spawn")
